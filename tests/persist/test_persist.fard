import("../../packages/kernel-persist/src/persist") as persist
import("../../packages/kernel-license/src/license") as license
import("../../packages/kernel-context/src/context") as ctx
import("std/rec") as rec
import("std/str") as str

let program_a = "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
let program_b = "sha256:bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
let registry = license.make_registry([program_a, program_b])

let msg = ctx.make_message("user", "hello world")
let sample_context = ctx.make_context([msg.ok], "claude-3", 1)

let reg_path = "/tmp/dek_test_registry.json"
let ctx_path = "/tmp/dek_test_context.json"
let bad_path = "/tmp/nonexistent_dir_xyz/dek_test.json"

test "save_registry returns ok" {
  let r = persist.save_registry(registry, reg_path) in
  rec.has(r, "ok")
}

test "save_registry ok contains path" {
  let r = persist.save_registry(registry, reg_path) in
  r.ok.path == reg_path
}

test "save_registry ok contains registry_cid" {
  let r = persist.save_registry(registry, reg_path) in
  str.starts_with(r.ok.registry_cid, "sha256:")
}

test "load_registry returns ok after save" {
  let s = persist.save_registry(registry, reg_path) in
  let l = persist.load_registry(reg_path) in
  rec.has(l, "ok")
}

test "load_registry cid matches save cid" {
  let s = persist.save_registry(registry, reg_path) in
  let l = persist.load_registry(reg_path) in
  l.ok.registry_cid == s.ok.registry_cid
}

test "load_registry roundtrip preserves is_licensed" {
  let s = persist.save_registry(registry, reg_path) in
  let l = persist.load_registry(reg_path) in
  license.is_licensed(program_a, l.ok.registry)
}

test "load_registry roundtrip rejects unlicensed" {
  let s = persist.save_registry(registry, reg_path) in
  let l = persist.load_registry(reg_path) in
  !license.is_licensed("sha256:cccc", l.ok.registry)
}

test "load_registry err for missing file" {
  let r = persist.load_registry("/tmp/does_not_exist_xyz_abc.json") in
  rec.has(r, "err") && r.err.code == "READ_FAILED"
}

test "save_context returns ok" {
  let r = persist.save_context(sample_context, ctx_path) in
  rec.has(r, "ok")
}

test "save_context ok contains context_cid" {
  let r = persist.save_context(sample_context, ctx_path) in
  str.starts_with(r.ok.context_cid, "sha256:")
}

test "load_context returns ok after save" {
  let s = persist.save_context(sample_context, ctx_path) in
  let l = persist.load_context(ctx_path) in
  rec.has(l, "ok")
}

test "load_context cid matches save cid" {
  let s = persist.save_context(sample_context, ctx_path) in
  let l = persist.load_context(ctx_path) in
  l.ok.context_cid == s.ok.context_cid
}

test "load_context roundtrip cid stable for truncation check" {
  let s = persist.save_context(sample_context, ctx_path) in
  let l = persist.load_context(ctx_path) in
  let r = ctx.truncation_check(s.ok.context_cid, l.ok.context) in
  rec.has(r, "ok") && r.ok.verified == true
}

test "load_context err for missing file" {
  let r = persist.load_context("/tmp/does_not_exist_xyz_abc.json") in
  rec.has(r, "err") && r.err.code == "READ_FAILED"
}
