{
  make_null: fn() { { t: "null" } },
  make_bool: fn(b) { { t: "bool", v: b } },
  make_int: fn(n) { { t: "int", v: n } },
  make_float_bits: fn(bits_hex) { { t: "float", bits_hex: bits_hex } },
  make_text: fn(s) { { t: "text", v: s } },
  make_bytes: fn(bs) { { t: "bytes", v: bs } },
  make_list: fn(xs) { { t: "list", v: xs } },
  make_record: fn(entries) { { t: "record", v: entries } },
  make_cid: fn(cid) { { t: "cid", v: cid } }
}
